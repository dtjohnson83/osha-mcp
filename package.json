{
  "name": "osha-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for OSHA compliance lookups - 29 CFR 1910 & 1926",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "osha-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "ingest": "tsx scripts/ingest-standards.ts",
    "summarize": "tsx scripts/generate-summaries.ts",
    "seed-penalties": "tsx scripts/seed-penalties.ts",
    "validate": "tsx scripts/validate-data.ts",
    "setup-db": "tsx scripts/setup-db.ts"
  },
  "keywords": ["osha", "safety", "compliance", "mcp"],
  "author": "DANZUS Holdings LLC",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.101.0",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
