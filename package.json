{
  "name": "osha-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for OSHA compliance lookups - 29 CFR 1910 & 1926",
  "type": "module",
  "main": "dist-server/index.js",
  "bin": {
    "osha-mcp-server": "dist-server/index.js"
  },
  "scripts": {
    "build": "rm -rf .next && tsc -p tsconfig.server.json && next build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "next build",
    "start": "node dist-server/index.js",
    "dev": "tsx src/index.ts",
    "dev:web": "next dev",
    "ingest": "tsx scripts/ingest-standards.ts",
    "summarize": "tsx scripts/generate-summaries.ts",
    "seed-penalties": "tsx scripts/seed-penalties.ts",
    "validate": "tsx scripts/validate-data.ts",
    "setup-db": "tsx scripts/setup-db.ts",
    "seed-naics": "tsx scripts/seed-naics.ts",
    "backfill": "tsx scripts/backfill-common-violations.ts",
    "seed-ppe": "tsx scripts/seed-ppe.ts"
  },
  "keywords": [
    "osha",
    "safety",
    "compliance",
    "mcp"
  ],
  "author": "DANZUS Holdings LLC",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.101.0",
    "dotenv": "^17.3.1",
    "next": "^16.2.1",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
